# Copy this file to .env for local development
# On Render, set these in the Environment tab — do NOT commit .env
ANTHROPIC_API_KEY=your-api-key-here

# Selah for Ministry (Pro) — auth wiring, added 2026-07-07
# SUPABASE_URL / SUPABASE_ANON_KEY are safe to expose to a browser (RLS is the
# real security boundary) but still belong in env vars, not hardcoded.
SUPABASE_URL=https://pdbqmwocqufkxvuonbef.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
# Used to sign Flask's session cookie -- generate a real random value for
# production (e.g. `python -c "import secrets; print(secrets.token_hex(32))"`),
# never reuse this placeholder.
FLASK_SECRET_KEY=change-me-to-a-real-random-value

# Usage-cap gate, added 2026-07-07. HIGHLY SENSITIVE -- bypasses Row Level
# Security entirely. Server-side only, never sent to a browser, never used
# for anything except reading/writing usage_records. Get it from the
# Supabase dashboard: Settings -> API -> service_role key.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional override for the free/beta tier's monthly conversation cap
# (placeholder value until real tiers/pricing are live) -- defaults to 30.
FREE_TIER_MONTHLY_CAP=30
