# Copy this file to .env for local development
# On Render, set these in the Environment tab — do NOT commit .env
ANTHROPIC_API_KEY=your-api-key-here

# Selah for Ministry (Pro) — auth wiring, added 2026-07-07
# SUPABASE_URL / SUPABASE_ANON_KEY are safe to expose to a browser (RLS is the
# real security boundary) but still belong in env vars, not hardcoded.
SUPABASE_URL=https://pdbqmwocqufkxvuonbef.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
# Used to sign Flask's session cookie -- generate a real random value for
# production (e.g. `python -c "import secrets; print(secrets.token_hex(32))"`),
# never reuse this placeholder.
FLASK_SECRET_KEY=change-me-to-a-real-random-value

# Usage-cap gate, added 2026-07-07. HIGHLY SENSITIVE -- bypasses Row Level
# Security entirely. Server-side only, never sent to a browser, never used
# for anything except reading/writing usage_records. Get it from the
# Supabase dashboard: Settings -> API -> service_role key.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional override for the free/beta tier's monthly conversation cap
# (placeholder value until real tiers/pricing are live) -- defaults to 30.
FREE_TIER_MONTHLY_CAP=30

# Stripe billing (pro_billing.py). Until STRIPE_SECRET_KEY is set, billing
# routes return a clean 503 instead of crashing -- the app can deploy with
# this code in place before real keys/Prices exist.
STRIPE_SECRET_KEY=your-stripe-secret-key-here
# Shown when this endpoint's URL (https://<domain>/pro/billing/webhook) is
# registered as a webhook destination in the Stripe dashboard.
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-signing-secret-here

# Individual Pro -- 3 tiers x 2 billing cycles (2026-07-09 pricing lock,
# commit 22c3d2c). Any annual price left unset falls back to that tier's
# monthly price -- a tier can go live monthly-only.
STRIPE_PRICE_EXPLORE_MONTHLY=
STRIPE_PRICE_EXPLORE_ANNUAL=
STRIPE_PRICE_PURSUE_MONTHLY=
STRIPE_PRICE_PURSUE_ANNUAL=
STRIPE_PRICE_IMMERSE_MONTHLY=
STRIPE_PRICE_IMMERSE_ANNUAL=
# $15 one-time, 100 exchanges -- Price ID wiring only, no working purchase
# flow yet (roadmap task #77).
STRIPE_PRICE_EXCHANGE_BLOCK=

# Church/Org seats (2026-07-12 pricing lock) -- ONE volume-tiered Price per
# seat type in Stripe (billing_scheme 'tiered', tiers_mode 'volume'), not a
# separate Price per bracket. Leadership: $14/$12/$10 (1-4/5-9/10+ seats),
# 200/mo pooled cap. Membership: $8/$7.50/$7/$6.50 (10-24/25-99/100-999/
# 1000+ seats, 10-seat minimum), 100/mo pooled cap. Created in Stripe
# 2026-07-12 (Leadership: price_1TsOtu3UvhMXNeQuBmBBPR1G, Membership:
# price_1TsOu43UvhMXNeQuqLxlrnpf).
STRIPE_PRICE_CHURCH_LEADERSHIP=
STRIPE_PRICE_CHURCH_MEMBER=
# Church/Org exchange block -- $15 one-time, 100 exchanges, buyable in
# quantity, credits whichever pooled seat_type (Leadership or Membership)
# the admin picks for the CURRENT calendar month only (not a rollover
# balance). New scope, not part of Section 17's original locked pricing --
# see pro_billing.py's STRIPE_PRICE_CHURCH_EXCHANGE_BLOCK docstring. Created
# in Stripe 2026-07-12: price_1TsQRf3UvhMXNeQuVDKWJzU6.
STRIPE_PRICE_CHURCH_EXCHANGE_BLOCK=
